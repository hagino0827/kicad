(kicad_mod SamplePart (version 20211014) (generator pcbnew)
  (info "Sample placeholder part - DRC friendly example")
  (properties (author "team") (company "OIT-HPA"))
  (fp_text reference REF** (at 0 -2.5) (layer F.SilkS) (effects (font (size 1 1) (thickness 0.15))))
  (fp_text value SAMPLE (at 0 2.5) (layer F.Fab) (effects (font (size 1 1) (thickness 0.15))))
  (pads
    (pad 1 thru_hole circle (at -2.54 0) (size 2.4 2.4) (drill 1.0) (layers *.Cu *.Mask) (net ""))
    (pad 2 thru_hole circle (at 2.54 0) (size 2.4 2.4) (drill 1.0) (layers *.Cu *.Mask) (net ""))
  )
  (model ${KIPRJMOD}/3dmodels/SamplePart.step (at (0 0 0)) (scale (1 1 1)))
)
